---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>{post.data.title} - sugargeng</title>
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={post.data.summary} />
  </head>

  <body>
    <main class="page">
      <a class="back" href="/writing/">← Writing</a>

      <article>
        <header>
          <time>{post.data.date}</time>
          <h1>{post.data.title}</h1>
          <p>{post.data.summary}</p>

          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
        </header>

        <div class="content">
          <Content />
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
    background: #080d1d;
    color: #e8edf7;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 72px 24px 104px;
  }

  .back {
    color: #9cc9ff;
    text-decoration: none;
  }

  header {
    margin-top: 52px;
    margin-bottom: 54px;
  }

  time {
    color: #9cc9ff;
    font-weight: 800;
  }

  h1 {
    margin: 20px 0;
    font-size: clamp(42px, 7vw, 76px);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  header p {
    color: #c4ccdc;
    font-size: 19px;
    line-height: 1.8;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .tags span {
    border: 1px solid rgba(156, 201, 255, 0.35);
    color: #9cc9ff;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 13px;
  }

  .content {
    color: #dce3f3;
    font-size: 18px;
    line-height: 1.9;
  }

  .content :global(h2) {
    margin-top: 46px;
    color: #f3f6ff;
    font-size: 30px;
    letter-spacing: -0.035em;
  }

  .content :global(h3) {
    margin-top: 34px;
    color: #f3f6ff;
    font-size: 24px;
  }

  .content :global(p) {
    margin: 18px 0;
  }

  .content :global(li) {
    margin: 8px 0;
  }

  .content :global(a) {
    color: #9cc9ff;
  }

  .content :global(code) {
    background: rgba(156, 201, 255, 0.12);
    padding: 2px 6px;
    border-radius: 6px;
  }

  .content :global(pre) {
    overflow-x: auto;
    padding: 18px;
    border-radius: 14px;
    background: rgba(2, 6, 16, 0.7);
  }

  .content :global(blockquote) {
    margin: 28px 0;
    padding-left: 20px;
    border-left: 3px solid #9cc9ff;
    color: #c4ccdc;
  }
</style>
