---
import { getCollection } from 'astro:content';

const logs = await getCollection('logs');

const sortedLogs = logs.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>Logs - sugargeng</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body>
    <main class="page">
      <a class="back" href="/">← Home</a>

      <section class="hero">
        <p class="eyebrow">DAILY LOGS</p>
        <h1>Logs</h1>
        <p class="desc">
          这里记录我的每日学习、问题复盘、技术理解和阶段性思考。
        </p>
      </section>

      <section class="list">
        {sortedLogs.map((log) => (
          <article class="card">
            <time>{log.data.date}</time>
            <h2>
              <a href={`/logs/${log.slug}/`}>{log.data.title}</a>
            </h2>
            <p>{log.data.summary}</p>

            {log.data.tags && (
              <div class="tags">
                {log.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            )}
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #080d1d;
    color: #e8edf7;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 72px 24px;
  }

  .back {
    color: #9cc9ff;
    text-decoration: none;
  }

  .hero {
    margin-top: 48px;
    margin-bottom: 56px;
  }

  .eyebrow {
    color: #8fc7ff;
    letter-spacing: 0.22em;
    font-size: 13px;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    font-size: clamp(64px, 9vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .desc {
    max-width: 680px;
    margin-top: 24px;
    color: #c4ccdc;
    font-size: 18px;
    line-height: 1.8;
  }

  .list {
    display: grid;
    gap: 24px;
  }

  .card {
    border: 1px solid rgba(166, 196, 255, 0.18);
    border-radius: 22px;
    padding: 28px;
    background: rgba(12, 20, 40, 0.72);
  }

  time {
    color: #c4ccdc;
    font-size: 14px;
  }

  h2 {
    margin: 14px 0 12px;
    font-size: 26px;
  }

  h2 a {
    color: #f3f6ff;
    text-decoration: none;
  }

  h2 a:hover {
    color: #9cc9ff;
  }

  .card p {
    color: #c4ccdc;
    line-height: 1.8;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .tags span {
    border: 1px solid rgba(156, 201, 255, 0.35);
    color: #9cc9ff;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 13px;
  }
</style>
