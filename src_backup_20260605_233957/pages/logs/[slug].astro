---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const logs = await getCollection('logs');

  return logs.map((log) => ({
    params: { slug: log.slug },
    props: { log },
  }));
}

const { log } = Astro.props;
const { Content } = await render(log);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>{log.data.title} - sugargeng</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body>
    <main class="page">
      <a class="back" href="/logs/">← Logs</a>

      <article>
        <header>
          <time>{log.data.date}</time>
          <h1>{log.data.title}</h1>
          <p>{log.data.summary}</p>

          {log.data.tags && (
            <div class="tags">
              {log.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
        </header>

        <div class="content">
          <Content />
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #080d1d;
    color: #e8edf7;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 72px 24px;
  }

  .back {
    color: #9cc9ff;
    text-decoration: none;
  }

  header {
    margin-top: 48px;
    margin-bottom: 48px;
  }

  time {
    color: #9cc9ff;
    font-weight: 700;
  }

  h1 {
    margin: 18px 0;
    font-size: clamp(42px, 7vw, 76px);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  header p {
    color: #c4ccdc;
    font-size: 18px;
    line-height: 1.8;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .tags span {
    border: 1px solid rgba(156, 201, 255, 0.35);
    color: #9cc9ff;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 13px;
  }

  .content {
    color: #dce3f3;
    font-size: 18px;
    line-height: 1.9;
  }

  .content :global(h2) {
    margin-top: 44px;
    color: #f3f6ff;
    font-size: 28px;
  }

  .content :global(p) {
    margin: 18px 0;
  }

  .content :global(li) {
    margin: 8px 0;
  }

  .content :global(code) {
    background: rgba(156, 201, 255, 0.12);
    padding: 2px 6px;
    border-radius: 6px;
  }
</style>
