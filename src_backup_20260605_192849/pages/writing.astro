---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Writing - sugargeng</title>
    <meta name="description" content="sugargeng 的写作与技术思考。" />
  </head>

  <body>
    <main>
      <header>
        <a href="/">← Home</a>
        <h1>Writing</h1>
        <p>关于 AI 应用开发、软件工程、项目复盘和长期成长的公开思考。</p>
      </header>

      <section class="posts">
        {posts.length === 0 && (
          <p class="empty">No posts found.</p>
        )}

        {posts.map((post) => (
          <article class="post-card">
            <p class="date">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
            <h2>
              <a href={`/writing/${post.id}`}>{post.data.title}</a>
            </h2>
            <p>{post.data.description}</p>
            <div class="tags">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    background: #0b1020;
    color: #e5e7eb;
  }

  main {
    width: min(920px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 120px;
  }

  header a {
    color: #93c5fd;
    text-decoration: none;
  }

  h1 {
    margin: 48px 0 20px;
    font-size: clamp(56px, 9vw, 104px);
    line-height: 0.95;
    letter-spacing: -0.075em;
  }

  header p {
    max-width: 720px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.8;
  }

  .posts {
    margin-top: 72px;
    display: grid;
    gap: 18px;
  }

  .empty {
    color: #fca5a5;
  }

  .post-card {
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 24px;
    padding: 28px;
    background: rgba(15, 23, 42, 0.72);
  }

  .date {
    margin: 0 0 12px;
    color: #94a3b8;
    font-size: 14px;
  }

  h2 {
    margin: 0 0 12px;
    font-size: 28px;
    letter-spacing: -0.03em;
  }

  h2 a {
    color: #f8fafc;
    text-decoration: none;
  }

  h2 a:hover {
    color: #93c5fd;
  }

  .post-card p {
    color: #cbd5e1;
    line-height: 1.8;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .tags span {
    border: 1px solid rgba(147, 197, 253, 0.24);
    border-radius: 999px;
    padding: 6px 12px;
    color: #93c5fd;
    font-size: 13px;
  }
</style>
