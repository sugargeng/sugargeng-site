---
import { getCollection, render } from 'astro:content';
import path from 'node:path';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => {
    const slug = path.basename(post.id).replace(/\.mdx?$/, '');

    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.data.title} - sugargeng</title>
    <meta name="description" content={post.data.description} />
  </head>

  <body>
    <main>
      <a class="back" href="/writing">← Writing</a>

      <article>
        <p class="date">
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </p>

        <h1>{post.data.title}</h1>
        <p class="description">{post.data.description}</p>

        <div class="tags">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>

        <div class="content">
          <Content />
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    background: #0b1020;
    color: #e5e7eb;
  }

  main {
    width: min(820px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 120px;
  }

  .back {
    color: #93c5fd;
    text-decoration: none;
  }

  article {
    margin-top: 56px;
  }

  .date {
    color: #94a3b8;
    font-size: 14px;
  }

  h1 {
    margin: 12px 0 20px;
    font-size: clamp(40px, 7vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .description {
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.8;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 28px 0 48px;
  }

  .tags span {
    border: 1px solid rgba(147, 197, 253, 0.24);
    border-radius: 999px;
    padding: 6px 12px;
    color: #93c5fd;
    font-size: 13px;
  }

  .content {
    color: #dbeafe;
    font-size: 18px;
    line-height: 1.95;
  }

  .content :global(p) {
    color: #cbd5e1;
  }

  .content :global(h2) {
    margin-top: 48px;
    color: #f8fafc;
  }

  .content :global(a) {
    color: #93c5fd;
  }
</style>
