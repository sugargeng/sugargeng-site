---
import { getCollection } from 'astro:content';

const logs = await getCollection('logs');

const sortedLogs = logs.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>Logs - sugargeng</title>
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="sugargeng 的学习日志，记录每日学习、问题复盘和阶段性思考。"
    />
  </head>

  <body>
    <main class="page">
      <a class="back" href="/">← Home</a>

      <section class="hero">
        <p class="eyebrow">DAILY LEARNING LOGS</p>
        <h1>Logs</h1>
        <p class="desc">
          这里不追求文章感，而是记录真实的学习过程：今天做了什么，卡在哪里，
          哪些地方还没掌握，以及下一步怎么改进。
        </p>
      </section>

      <section class="list">
        {sortedLogs.map((log) => (
          <article class="card">
            <time>{log.data.date}</time>

            <h2>
              <a href={`/logs/${log.id.replace(/\.mdx?$/, '')}/`}>
                {log.data.title}
              </a>
            </h2>

            <p>{log.data.summary}</p>

            {log.data.tags.length > 0 && (
              <div class="tags">
                {log.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            )}
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
    color: #eef3ff;
    background:
      radial-gradient(circle at 86% 8%, rgba(92, 48, 160, 0.28), transparent 32%),
      #080d1d;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 72px 24px 96px;
  }

  .back {
    color: #9cc9ff;
    text-decoration: none;
  }

  .hero {
    margin-top: 54px;
    margin-bottom: 58px;
  }

  .eyebrow {
    margin: 0 0 24px;
    color: #8fc7ff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.22em;
  }

  h1 {
    margin: 0;
    font-size: clamp(64px, 10vw, 116px);
    line-height: 0.95;
    letter-spacing: -0.075em;
  }

  .desc {
    max-width: 760px;
    margin-top: 28px;
    color: #c4ccdc;
    font-size: 19px;
    line-height: 1.85;
  }

  .list {
    display: grid;
    gap: 24px;
  }

  .card {
    padding: 30px;
    border: 1px solid rgba(166, 196, 255, 0.18);
    border-radius: 22px;
    background: rgba(12, 20, 40, 0.72);
  }

  time {
    color: #b9c5dc;
    font-size: 14px;
  }

  h2 {
    margin: 14px 0 12px;
    font-size: 28px;
    letter-spacing: -0.04em;
  }

  h2 a {
    color: #f3f6ff;
    text-decoration: none;
  }

  h2 a:hover {
    color: #9cc9ff;
  }

  .card p {
    color: #c4ccdc;
    line-height: 1.85;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .tags span {
    border: 1px solid rgba(156, 201, 255, 0.35);
    color: #9cc9ff;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 13px;
  }
</style>
